      "NEXT_PUBLIC_AI_MODEL": "@ai-model",
      "CLASSIFIER_BASE_URL": "@classifier-base-url",
      "CLASSIFIER_API_KEY": "@classifier-api-key",
      "CLASSIFIER_MODEL": "@classifier-model",
      "NEXT_PUBLIC_SUPABASE_URL": "@supabase-url",
